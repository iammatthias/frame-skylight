# Public iCloud Shared Album link ("anyone with the link can view").
# The newer photos.icloud.com/shared/album/<token> form works directly.
ALBUM_URL=https://photos.icloud.com/shared/album/0b19xxxxxxxxxxxxxxxxx

# Frame's network-adb endpoint (its LAN IP : 5555).
FRAME_HOST=192.168.50.72:5555

# How often to reconcile the album into the frame, seconds.
POLL_INTERVAL=300

# Plan only — log what would change without writing to the frame. "1" to enable.
DRY_RUN=

# Status endpoint (GET /status). With host networking this binds on the beelink;
# reachable at http://<beelink>:8780/status on the LAN/tailnet.
STATUS_ADDR=0.0.0.0
STATUS_PORT=8780
